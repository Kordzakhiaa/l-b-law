# See https://docs.github.com/get-started/getting-started-with-git/ignoring-files

# --- Angular / build output ---
/dist
/tmp
/out-tsc
/bazel-out
/.angular/cache

# --- Dependencies ---
node_modules/

# --- Logs & diagnostics ---
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
testem.log
/libpeerconnection.log
/connect.lock

# --- Test & coverage ---
/coverage
.nyc_output
__screenshots__/

# --- TypeScript / tooling caches ---
*.tsbuildinfo
.eslintcache
.prettiercache
.sass-cache/
/typings

# --- Local secrets (do not commit real keys) ---
.env
.env.*
!.env.example

# Optional: local-only Angular environment overrides (uncomment if you use this pattern)
# /src/environments/environment.local.ts

# --- IDEs & editors ---
.idea/
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Visual Studio Code — track shared workspace config only
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/mcp.json
.history/*

# --- OS ---
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
ehthumbs.db
Desktop.ini

# --- Misc ---
*.tgz
*.pid
*.seed
*.pid.lock
